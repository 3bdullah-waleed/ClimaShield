      "source": [
        "# Permutation importance (more robust than default impurity-based importance)\n",
        "from sklearn.inspection import permutation_importance\n",
        "\n",
        "perm_result = permutation_importance(rf_model, X_test, y_test, n_repeats=20,\n",
        "                                      random_state=RANDOM_STATE, n_jobs=-1)\n",
        "perm_importances = pd.Series(perm_result.importances_mean, index=feature_cols).sort_values(ascending=False)\n",
        "\n",
        "print(perm_importances.round(4))\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "sns.barplot(x=perm_importances.values, y=perm_importances.index, palette='Oranges_r')\n",
        "plt.xlabel('Mean decrease in accuracy when shuffled')\n",
        "plt.title('Permutation Feature Importance (Test Set)')\n",
        "plt.tight_layout()\n",
        "plt.show()\n"
      ]
    },
