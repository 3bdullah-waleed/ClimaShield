      "source": [
        "train_sizes, train_scores, val_scores = learning_curve(\n",
        "    RandomForestClassifier(n_estimators=200, random_state=RANDOM_STATE, n_jobs=-1),\n",
        "    X, y, cv=5, scoring='accuracy',\n",
        "    train_sizes=np.linspace(0.1, 1.0, 8), n_jobs=-1\n",
        ")\n",
