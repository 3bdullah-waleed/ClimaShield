          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 700x600 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "y_test_bin = label_binarize(y_test, classes=labels_order)\n",
        "y_score = rf_model.predict_proba(X_test)\n",
        "# reorder predict_proba columns to match labels_order\n",
        "class_to_idx = {c: i for i, c in enumerate(rf_model.classes_)}\n",
        "y_score_ordered = y_score[:, [class_to_idx[c] for c in labels_order]]\n",
        "\n",
        "plt.figure(figsize=(7,6))\n",
        "colors = {'SAFE':'#27AE60','THIRST':'#E67E22','HEAT':'#E74C3C'}\n",
        "\n",
        "for i, label in enumerate(labels_order):\n",
        "    fpr, tpr, _ = roc_curve(y_test_bin[:, i], y_score_ordered[:, i])\n",
        "    roc_auc = auc(fpr, tpr)\n",
        "    plt.plot(fpr, tpr, color=colors[label], lw=2, label=f'{label} (AUC = {roc_auc:.3f})')\n",
        "\n",
        "plt.plot([0,1],[0,1],'k--', lw=1, label='Random guess')\n",
        "plt.xlabel('False Positive Rate')\n",
        "plt.ylabel('True Positive Rate')\n",
        "plt.title('ROC Curves — One-vs-Rest')\n",
        "plt.legend(loc='lower right')\n",
        "plt.show()\n"
      ]
    },
