        "train_mean = train_scores.mean(axis=1)\n",
        "val_mean = val_scores.mean(axis=1)\n",
        "\n",
        "plt.figure(figsize=(7,5))\n",
        "plt.plot(train_sizes, train_mean, 'o-', color='#27AE60', label='Training accuracy')\n",
