    {
      "cell_type": "markdown",
      "source": [
        "## 8b. Noise-Robustness Stress Test\n",
        "\n",
        "The test accuracy above (99.7%) was measured on clean, rule-generated data — it tells us the model learned the labelling rules correctly, not how it will behave with real, noisy sensor readings.\n",
        "\n",
        "Real hardware (DHT22, capacitive soil sensor, BH1750, DS18B20, HC-SR04) produces jittery values due to sensor tolerance, calibration drift, and electrical noise. This test simulates that by injecting realistic noise into the test set and re-measuring accuracy — this is the number that actually reflects demo-day reliability."
      ],
      "metadata": {
        "id": "i8fwUDTC-sJG"
      },
      "id": "i8fwUDTC-sJG"
    },
    {
      "cell_type": "code",
      "source": [
        "# Simulate realistic sensor noise based on each sensor's datasheet tolerance\n",
        "np.random.seed(RANDOM_STATE)\n",
        "\n",
        "def add_sensor_noise(X, noise_levels):\n",
        "    \"\"\"Add Gaussian noise to each feature based on real sensor accuracy specs.\"\"\"\n",
        "    X_noisy = X.copy()\n",
        "    for col, std in noise_levels.items():\n",
        "        X_noisy[col] = X_noisy[col] + np.random.normal(0, std, size=len(X_noisy))\n",
        "    return X_noisy\n",
        "\n",
        "# Noise std-dev per sensor, based on datasheet tolerances used in the dataset generation\n",
        "noise_levels = {\n",
        "    'Air_Temp_C': 0.5,              # DHT22 accuracy ±0.5°C\n",
        "    'Air_Humidity_Pct': 2.0,        # DHT22 accuracy ±2-5%\n",
        "    'Solar_Radiation_W_m2': 15.0,   # BH1750 ±20% at high intensities (approximated as std)\n",
        "    'Soil_Moisture_Pct': 3.0,       # Capacitive sensor noise\n",
        "    'Root_Temp_C': 0.3,             # DS18B20 accuracy ±0.5°C\n",
        "    'Tank_Level_Pct': 2.0,          # HC-SR04 echo variability\n",
        "}\n",
        "\n",
        "def recompute_vpd(df_):\n",
        "    T = df_['Air_Temp_C']\n",
        "    RH = df_['Air_Humidity_Pct']\n",
        "    return 0.6108 * np.exp(17.27 * T / (T + 237.3)) * (1 - RH/100)\n",
        "\n",
        "def relabel(row):\n",
        "    c1 = row['Air_Temp_C'] >= 38.0\n",
        "    c2 = row['Solar_Radiation_W_m2'] > 700.0\n",
        "    c3 = row['Root_Temp_C'] > 36.0\n",
        "    c4 = row['VPD_kPa'] > 3.5\n",
        "    c5 = (row['Air_Temp_C'] > 33) and (row['Air_Humidity_Pct'] < 20) and (row['Solar_Radiation_W_m2'] > 500)\n",
        "    if c1 or c2 or c3 or c4 or c5:\n",
        "        return 'HEAT'\n",
        "    elif row['Soil_Moisture_Pct'] < 35.0:\n",
        "        return 'THIRST'\n",
        "    else:\n",
        "        return 'SAFE'\n",
        "\n",
        "print(\"Testing model robustness across increasing noise levels...\\n\")\n",
        "\n",
        "multipliers = [0.5, 1.0, 1.5, 2.0, 3.0]  # fractions of base sensor noise\n",
        "results = []\n",
        "\n",
        "for mult in multipliers:\n",
        "    scaled_noise = {k: v * mult for k, v in noise_levels.items()}\n",
        "    X_test_noisy = add_sensor_noise(X_test, scaled_noise)\n",
        "\n",
        "    # Clip to physically valid ranges after adding noise\n",
        "    X_test_noisy['Air_Temp_C'] = X_test_noisy['Air_Temp_C'].clip(10, 50)\n",
        "    X_test_noisy['Air_Humidity_Pct'] = X_test_noisy['Air_Humidity_Pct'].clip(2, 100)\n",
        "    X_test_noisy['Solar_Radiation_W_m2'] = X_test_noisy['Solar_Radiation_W_m2'].clip(0, 1100)\n",
        "    X_test_noisy['Soil_Moisture_Pct'] = X_test_noisy['Soil_Moisture_Pct'].clip(0, 100)\n",
        "    X_test_noisy['Root_Temp_C'] = X_test_noisy['Root_Temp_C'].clip(5, 55)\n",
        "    X_test_noisy['Tank_Level_Pct'] = X_test_noisy['Tank_Level_Pct'].clip(0, 100)\n",
        "\n",
        "    # Recompute VPD from the NOISY temp/humidity (physically consistent, as a real sensor pipeline would)\n",
        "    X_test_noisy['VPD_kPa'] = recompute_vpd(X_test_noisy)\n",
        "\n",
        "    # Re-derive the TRUE label for the noisy conditions (ground truth shifts slightly with noise too)\n",
        "    true_labels_noisy = X_test_noisy.apply(relabel, axis=1)\n",
        "\n",
        "    # Model predicts on noisy input\n",
        "    y_pred_noisy = final_model.predict(X_test_noisy[feature_cols])\n",
        "\n",
        "    acc_vs_original_label = accuracy_score(y_test, y_pred_noisy)       # vs original clean label\n",
        "    acc_vs_true_noisy_label = accuracy_score(true_labels_noisy, y_pred_noisy)  # vs \"correct\" label given noisy conditions\n",
        "\n",
        "    results.append({\n",
        "        'noise_multiplier': mult,\n",
        "        'accuracy_vs_original_label': acc_vs_original_label,\n",
        "        'accuracy_vs_recomputed_label': acc_vs_true_noisy_label\n",
        "    })\n",
        "\n",
        "    print(f\"Noise level {mult}x sensor tolerance:\")\n",
        "    print(f\"  Accuracy vs original (pre-noise) label:  {acc_vs_original_label:.4f}\")\n",
        "    print(f\"  Accuracy vs recomputed (true) label:      {acc_vs_true_noisy_label:.4f}\\n\")\n",
        "\n",
        "results_df = pd.DataFrame(results)\n",
        "results_df"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 588
        },
        "id": "XiEsZ6Ww-6ll",
