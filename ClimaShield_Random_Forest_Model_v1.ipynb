      "source": [
        "## 14. Try a Single Prediction (Simulated Sensor Reading)\n",
        "\n",
        "This mirrors exactly what the Raspberry Pi control loop will do: take one row of live sensor values and get back SAFE / HEAT / THIRST plus the model's confidence.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 28,
      "id": "01d19814",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "01d19814",
        "outputId": "6ce01c08-9d01-4cae-9097-3efb44e5b61b"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Predicted status: HEAT\n",
            "Class probabilities: {'HEAT': np.float64(1.0), 'SAFE': np.float64(0.0), 'THIRST': np.float64(0.0)}\n"
          ]
        }
      ],
      "source": [
        "def predict_status(air_temp, air_humidity, solar_radiation, soil_moisture, root_temp, vpd, tank_level):\n",
        "    sample = pd.DataFrame([{\n",
        "        'Air_Temp_C': air_temp,\n",
        "        'Air_Humidity_Pct': air_humidity,\n",
        "        'Solar_Radiation_W_m2': solar_radiation,\n",
        "        'Soil_Moisture_Pct': soil_moisture,\n",
        "        'Root_Temp_C': root_temp,\n",
        "        'VPD_kPa': vpd,\n",
        "        'Tank_Level_Pct': tank_level\n",
        "    }])\n",
        "    pred = final_model.predict(sample)[0]\n",
        "    proba = final_model.predict_proba(sample)[0]\n",
        "    proba_dict = dict(zip(final_model.classes_, proba.round(3)))\n",
        "    return pred, proba_dict\n",
        "\n",
        "# Example: Riyadh midday peak conditions\n",
        "pred, proba = predict_status(\n",
        "    air_temp=42.0, air_humidity=12.0, solar_radiation=850.0,\n",
        "    soil_moisture=40.0, root_temp=45.0, vpd=6.2, tank_level=70.0\n",
        ")\n",
        "print(\"Predicted status:\", pred)\n",
        "print(\"Class probabilities:\", proba)\n"
      ]
    },
